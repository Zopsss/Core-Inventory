// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  receipts   Receipt[]
  deliveries Delivery[]
  transfers  Transfer[]
  moves      Move[]
}

model Product {
  id        String   @id @default(cuid())
  name      String
  sku       String   @unique
  category  String
  unit      String // kg, pcs, litre, etc.
  minStock  Int      @default(0) // for low stock alerts
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks        Stock[]
  receiptItems  ReceiptItem[]
  deliveryItems DeliveryItem[]
  transferItems TransferItem[]
  moves         Move[]
}

model Stock {
  id       String @id @default(cuid())
  quantity Int    @default(0)

  productId  String
  locationId String

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId])
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  shortCode String   @unique
  address   String?
  createdAt DateTime @default(now())

  locations Location[]
}

model Location {
  id          String    @id @default(cuid())
  name        String
  shortCode   String    @unique
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  stocks        Stock[]
  receiptItems  ReceiptItem[]
  deliveryItems DeliveryItem[]
  fromTransfers TransferItem[] @relation("FromLocation")
  toTransfers   TransferItem[] @relation("ToLocation")
}

model Receipt {
  id        String        @id @default(cuid())
  reference String        @unique @default(cuid())
  supplier  String
  status    ReceiptStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId String
  user   User          @relation(fields: [userId], references: [id])
  items  ReceiptItem[]
  moves  Move[]
}

model ReceiptItem {
  id         String @id @default(cuid())
  quantity   Int
  receiptId  String
  productId  String
  locationId String

  receipt  Receipt  @relation(fields: [receiptId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
}

model Delivery {
  id        String         @id @default(cuid())
  reference String         @unique @default(cuid())
  customer  String
  status    DeliveryStatus @default(DRAFT)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  userId String
  user   User           @relation(fields: [userId], references: [id])
  items  DeliveryItem[]
  moves  Move[]
}

model DeliveryItem {
  id         String @id @default(cuid())
  quantity   Int
  deliveryId String
  productId  String
  locationId String

  delivery Delivery @relation(fields: [deliveryId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
}

model Transfer {
  id        String         @id @default(cuid())
  reference String         @unique @default(cuid())
  status    TransferStatus @default(DRAFT)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  userId String
  user   User           @relation(fields: [userId], references: [id])
  items  TransferItem[]
  moves  Move[]
}

model TransferItem {
  id             String @id @default(cuid())
  quantity       Int
  transferId     String
  productId      String
  fromLocationId String
  toLocationId   String

  transfer     Transfer @relation(fields: [transferId], references: [id])
  product      Product  @relation(fields: [productId], references: [id])
  fromLocation Location @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location @relation("ToLocation", fields: [toLocationId], references: [id])
}

model Move {
  id        String   @id @default(cuid())
  type      MoveType
  quantity  Int
  note      String?
  createdAt DateTime @default(now())

  productId  String
  userId     String
  receiptId  String?
  deliveryId String?
  transferId String?

  product  Product   @relation(fields: [productId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  receipt  Receipt?  @relation(fields: [receiptId], references: [id])
  delivery Delivery? @relation(fields: [deliveryId], references: [id])
  transfer Transfer? @relation(fields: [transferId], references: [id])
}

enum ReceiptStatus {
  DRAFT
  READY
  DONE
  CANCELLED
}

enum DeliveryStatus {
  DRAFT
  READY
  DONE
  CANCELLED
}

enum TransferStatus {
  DRAFT
  READY
  DONE
  CANCELLED
}

enum MoveType {
  IN // receipt
  OUT // delivery
  TRANSFER // internal
  ADJUSTMENT // stock adjust
}
